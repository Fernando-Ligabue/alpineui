{
  "name": "alpineui",
  "version": "0.1.0",
  "private": true,
  "description": "A collection of re-usable components built with Alpine.js and Tailwind CSS",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @Fernando-Ligabue/cli",
    "build": "npm run build -w @Fernando-Ligabue/cli",
    "test": "npm run test -w @Fernando-Ligabue/cli",
    "docs:dev": "npm run dev -C docs",
    "docs:build": "npm run build -C docs",
    "docs:preview": "npm run preview -C docs"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "components",
    "ui",
    "tailwindcss",
    "tailwind"
  ],
  "author": "Fernando-Ligabue",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fernando-Ligabue/alpineui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
